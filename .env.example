# =============================================================================
# Rahi — consolidated env reference (ALL variable names, one file)
# =============================================================================
# Secrets live in DOPPLER, never committed. This file lists every variable name
# used across the three Doppler projects so you can paste/import in one go and
# fill values later. Grouped by project. (rahi-docs/12 §2, /01 §6)
#
# Copy a group into the matching Doppler project's config and fill the values.
#   rahi-api        → server (private keys OK)
#   rahi-mobile     → app    (PUBLIC keys ONLY — these ship to devices)
#   rahi-powersync  → sync service ↔ Supabase connection
# =============================================================================


# -----------------------------------------------------------------------------
# Project: rahi-api   (NestJS backend — server-side, private)
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# Supabase (ap-south-1 / Mumbai)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# MSG91 (SMS / OTP — DLT templates)
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=

# Sentry (api project)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Upstash Redis (BullMQ — Phase 1+)
REDIS_URL=

# Cloudflare R2 (tiles / media / docs) — used Phase 2+
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_TILES=rahi-tiles
R2_BUCKET_MEDIA=rahi-media
R2_BUCKET_DOCS=rahi-docs
R2_PUBLIC_BASE_URL=

# GraphHopper (self-hosted routing) — Phase 2+
GRAPHHOPPER_BASE_URL=

# Overpass (OSM POI ingestion) — Phase 3+
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Razorpay (trip money rail) — Phase 5
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# RevenueCat (subscription rail — server validation + webhooks) — Phase 5
REVENUECAT_SECRET_API_KEY=
REVENUECAT_WEBHOOK_AUTH_HEADER=

# Open-Meteo (weather) — Phase 9 (no key needed; base URL only)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1


# -----------------------------------------------------------------------------
# Project: rahi-mobile   (Expo app — PUBLIC values ONLY; mirrored to EAS secrets)
# -----------------------------------------------------------------------------
# NEVER put SERVICE_ROLE / SECRET keys here — this ships to devices.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_POWERSYNC_URL=
EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Project: rahi-powersync   (PowerSync ↔ Supabase connection)
# -----------------------------------------------------------------------------
POWERSYNC_INSTANCE_URL=
# Postgres connection PowerSync replicates from (Supabase → Settings → Database)
SUPABASE_DB_CONNECTION_URI=
# Verify app JWTs at the sync service (same value as SUPABASE_JWT_SECRET above)
SUPABASE_JWT_SECRET=
