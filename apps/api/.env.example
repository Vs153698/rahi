# apps/api — environment contract. Real values come from Doppler (project rahi-api),
# never committed. Copy to .env only for local non-secret experimentation.
# TODO(phase-0-provisioning): fill these once accounts exist (rahi-docs/12 §2).

NODE_ENV=development
PORT=3000

# Supabase (Mumbai / ap-south-1) — rahi-docs/01 §5
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=                       # verify in Supabase dashboard
SUPABASE_SERVICE_ROLE_KEY=               # server-only; never ship to client
SUPABASE_JWT_SECRET=                     # used to verify auth JWTs

# MSG91 (SMS / OTP, DLT-template-ready) — rahi-docs/10
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=

# Sentry (api project) — rahi-docs (Task 0.9)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Redis / Upstash (BullMQ — used from Phase 1+)
REDIS_URL=
